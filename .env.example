# WalletConnect Project ID for mobile wallet support
# Get your project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=3ad651703bdec3b682ddb69769af9fff

# JWT Secret for development only
# Copy this file to .env.local and set a strong secret (at least 32 characters)
# For production, use: wrangler secret put JWT_SECRET
# JWT_SECRET=your-development-jwt-secret-key-here

# Firebase (client, Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# WalletConnect + Firebase notes:
# - Set the VITE_* vars above from your Firebase Web app config.
# - In production, set FIREBASE_PROJECT_ID in wrangler.toml [vars] for Firebase ID token verification.

# Google Health (wrangler.toml [vars] — separate GCP project from Firebase):
# GOOGLE_HEALTH_PROJECT_ID=your-health-gcp-project-id
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_REDIRECT_URI=https://your-host/api/integrations/google-health/callback
# wrangler secret put GOOGLE_OAUTH_CLIENT_SECRET
